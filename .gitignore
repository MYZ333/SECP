# ==========================================================
# 智慧医养项目 · 根 .gitignore
# ==========================================================

# ---------- Java / Maven (backend) ----------
backend/target/
**/target/
*.jar
*.war
*.class
!.mvn/wrapper/maven-wrapper.jar
backend/logs/
*.log

# ---------- Node / 前端 (web & miniprogram) ----------
node_modules/
**/node_modules/
web/dist/
miniprogram/dist/
miniprogram/unpackage/
.npm/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
*.local

# uni-app 编译产物
**/unpackage/

# ---------- 环境 / 敏感配置 ----------
# 若把真实密码/密钥单独放到本地配置文件，可在此忽略
application-local.yml
application-prod.yml
.env
.env.local
.env.*.local
*.pem
*.key

# ---------- IDE / 编辑器 ----------
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.sublime-*
.settings/
.project
.classpath
.factorypath

# ---------- 操作系统 ----------
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ---------- 其他 ----------
*.tmp
*.bak
*.swp
out/
build/
dist/
.cache/

uploads/avatar/


# ---------- RAG 本机运行数据（保留 data/rag/input 示例语料） ----------
data/rag/chroma/
data/rag/documents/
scripts/.chroma-venv/

# ---------- Local product documentation (do not commit) ----------
/PRODUCT.md
/docs/

# ---------- Local planning and runtime uploads ----------
/SECP/
/backend/uploads/

# ---------- Deployment package ----------
/deploy/
