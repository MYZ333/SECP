# ===== 环境变量模板 =====
# 用法：复制本文件为 .env，再填入真实值（.env 已被 .gitignore 忽略，不会提交）
#   cp .env.example .env
# 密钥请通过私密渠道共享，切勿提交进 Git。

# 数据库 root 密码（MySQL 容器会用它建库，后端也用它连接）
# 生成示例：openssl rand -hex 12
DB_PASSWORD=

# JWT 签名密钥（至少 32 字节）
# 生成示例：openssl rand -hex 32
JWT_SECRET=

# 敏感字段落库加密密钥
# 生成示例：openssl rand -hex 24
HDA_AES_KEY=

# ===== RSA 密码传输密钥对（可选，单机可留空自动生成；多节点部署必须配置固定密钥对）=====
# X.509 公钥 / PKCS#8 私钥的 Base64（单行，去掉 PEM 头尾）
RSA_PUBLIC_KEY=
RSA_PRIVATE_KEY=

# ===== 阿里云短信（可选，没有就留空，验证码会打印到后端日志）=====
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# ===== AI 大模型（可选，没接就留占位，健康咨询返回占位文案）=====
APIKEY=sk-placeholder
AI_CHAT_MODEL=qwen3.7-plus
AI_EMBEDDING_MODEL=text-embedding-v4
AI_DASHSCOPE_WORKSPACE_ID=
CHROMA_PORT=8000
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database
CHROMA_COLLECTION=medical_knowledge
CHROMA_KNOWLEDGE_COLLECTION=medical_knowledge
CHROMA_MEMORY_COLLECTION=long_term_memory
LONG_TERM_MEMORY_ENABLED=true
RAG_QUERY_REWRITE_ENABLED=true
RAG_HYBRID_ENABLED=true
RAG_KEYWORD_TOP_K=20
RAG_RERANK_TOP_K=12
RAG_VECTOR_WEIGHT=1.0
RAG_KEYWORD_WEIGHT=0.8
AGENT_INTAKE_ENABLED=true
AGENT_INTAKE_MAX_ROUNDS=6
